            android:theme="@style/Theme.GravitySDK" />
        <activity
            android:name=".LoginEventActivity"
            android:exported="false"
            android:label="Login Event"
            android:theme="@style/Theme.GravitySDK" />
        <activity
            android:name=".ChooseSelectorActivity"
            android:exported="false"
            android:label="Choose Selector"
            android:theme="@style/Theme.GravitySDK" />
    </application>

</manifest>
<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.GravitySDK"
        tools:targetApi="31">
        <activity
            android:name=".InlineProductsActivity"
            android:exported="false"
            android:label="Inline products"
            android:theme="@style/Theme.AppCompat.Light" />
        <activity
            android:name=".InlineBannerActivity"
            android:exported="false"
            android:label="Inline banner"
            android:theme="@style/Theme.AppCompat.Light" />
        <activity
            android:name=".InlineDemoActivity"
            android:exported="false"
            android:label="Inline demo"
            android:theme="@style/Theme.AppCompat.Light" />
        <activity
            android:name=".InlineListDemoActivity"
            android:exported="false"
            android:label="InlineList demo"
            android:theme="@style/Theme.AppCompat.Light" />
        <activity
            android:name=".WebViewActivity"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:exported="false"
            android:theme="@style/Theme.AppCompat.Light" />
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.GravitySDK">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".TestViewActivity"
            android:exported="false"
            android:label="Test View"
            android:theme="@style/Theme.GravitySDK" />
        <activity
            android:name=".CustomEventActivity"
            android:exported="false"
            android:label="Custom Event"
            android:theme="@style/Theme.GravitySDK" />
        <activity
            android:name=".AddToCartEventActivity"
            android:exported="false"
            android:label="Add To Cart Event"
            android:theme="@style/Theme.GravitySDK" />
        <activity
            android:name=".PurchaseEventActivity"
            android:exported="false"
            android:label="Purchase Event"
            android:theme="@style/Theme.GravitySDK" />
        <activity
            android:name=".RemoveFromCartEventActivity"
            android:exported="false"
            android:label="Remove From Cart Event"
            android:theme="@style/Theme.GravitySDK" />
        <activity
            android:name=".SyncCartEventActivity"
            android:exported="false"
            android:label="Sync Cart Event"
            android:theme="@style/Theme.GravitySDK" />
        <activity
            android:name=".AddToWishlistEventActivity"
